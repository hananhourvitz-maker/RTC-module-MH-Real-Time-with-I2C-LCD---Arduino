#include <Wire.h> 
#include <LiquidCrystal_I2C.h>
#include <ThreeWire.h>  
#include <RtcDS1302.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);
ThreeWire myWire(3, 2, 4); 
RtcDS1302<ThreeWire> Rtc(myWire);

// הגדרת פינים
const int BTN_SET = 5;
const int BTN_UP = 6;
const int BTN_DOWN = 7;
const int BUZZER = 8;

// הגדרת מצב לחוץ (בחיבור PULLUP לחוץ זה LOW)
const int PRESSED = LOW;

// משתני השעון המעורר
int alarmHour = 7;      // שעת ברירת מחדל
int alarmMinute = 0;    // דקת ברירת מחדל
bool isAlarmOn = false; // האם השעון המעורר פעיל
bool isRinging = false; // האם השעון מצלצל כרגע

// מצבי המערכת
enum SystemMode { SHOW_TIME, SET_ALARM_HOUR, SET_ALARM_MINUTE };
SystemMode currentMode = SHOW_TIME;

// משתני זמנים למסך ולכפתורים
unsigned long lastScreenToggle = 0;
bool showAlarmScreen = false; // flag למעבר בין מסך שעון למסך התראה

// משתנים לשמירת מצב כפתור קודם (למניעת קריאות כפולות)
bool prevSet = false;
bool prevUp = false;
bool prevDown = false;

void setup() {
    Serial.begin(9600);
    
    pinMode(BTN_SET, INPUT_PULLUP);
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BUZZER, OUTPUT);
    digitalWrite(BUZZER, LOW);
    
    lcd.init();
    lcd.backlight();
    lcd.clear();
    
    Rtc.Begin();
    if (Rtc.GetIsWriteProtected()) Rtc.SetIsWriteProtected(false);
    if (!Rtc.GetIsRunning()) Rtc.SetIsRunning(true);

    RtcDateTime now = Rtc.GetDateTime();
    if (!now.IsValid() || now.Year() < 2026) {
        RtcDateTime compiled = RtcDateTime(__DATE__, __TIME__);
        Rtc.SetDateTime(compiled);
    }
}

void loop() {
    RtcDateTime now = Rtc.GetDateTime();
    unsigned long currentMillis = millis();

    // קריאת מצב הכפתורים הנוכחי (הופכים לוגיקה: לחוץ = true, לא לחוץ = false)
    bool currSet = (digitalRead(BTN_SET) == PRESSED);
    bool currUp = (digitalRead(BTN_UP) == PRESSED);
    bool currDown = (digitalRead(BTN_DOWN) == PRESSED);

    // זיהוי לחיצה רגעית (עליית מצב מ-false ל-true)
    bool setTriggered = (currSet && !prevSet);
    bool upTriggered = (currUp && !prevUp);
    bool downTriggered = (currDown && !prevDown);

    // שמירת המצב הנוכחי לסיבוב הבא
    prevSet = currSet;
    prevUp = currUp;
    prevDown = currDown;

    // --- 1. בדיקת לחיצה משולבת: UP + DOWN יחד (לביטול יזום בכל שלב) ---
    if (currUp && currDown) {
        if (isAlarmOn || isRinging) {
            isAlarmOn = false;
            isRinging = false;
            lcd.clear();
            lcd.setCursor(0, 0);
            lcd.print("Alarm Disabled!");
            delay(1500); // השהייה קלה להצגת ההודעה
            lcd.clear();
        }
    } 
    // --- 2. תפעול במצבים השונים ---
    else {
        // לחיצה על SET
        if (setTriggered) {
            // תרחיש א': אם השעון מצלצל כרגע -> השתק ובטל את ההתראה!
            if (isRinging) {
                isRinging = false;
                isAlarmOn = false;
                lcd.clear();
                lcd.setCursor(0, 0);
                lcd.print("Alarm Stopped!");
                delay(1500);
                lcd.clear();
            } 
            // תרחיש ב': שימוש רגיל ב-SET לצורך הגדרת זמנים
            else {
                if (currentMode == SHOW_TIME) {
                    currentMode = SET_ALARM_HOUR;
                } else if (currentMode == SET_ALARM_HOUR) {
                    currentMode = SET_ALARM_MINUTE;
                } else if (currentMode == SET_ALARM_MINUTE) {
                    currentMode = SHOW_TIME;
                    isAlarmOn = true; // הפעלה אוטומטית של ההתראה לאחר סיום ההגדרה
                    lcd.clear();
                    lcd.print("Alarm Saved & ON");
                    delay(1500);
                    lcd.clear();
                }
            }
        }

        // שינוי ערכים בהתאם למצב הנוכחי (רק אם אנחנו לא בזמן צלצול)
        if (!isRinging) {
            if (currentMode == SET_ALARM_HOUR) {
                if (upTriggered) alarmHour = (alarmHour + 1) % 24;
                if (downTriggered) alarmHour = (alarmHour == 0) ? 23 : alarmHour - 1;
            } 
            else if (currentMode == SET_ALARM_MINUTE) {
                if (upTriggered) alarmMinute = (alarmMinute + 1) % 60;
                if (downTriggered) alarmMinute = (alarmMinute == 0) ? 59 : alarmMinute - 1;
            }
        }
    }

    // --- 3. ניהול החלפת מסכים אוטומטית (כל 5 שניות) במסך הראשי ---
    if (currentMode == SHOW_TIME) {
        if (currentMillis - lastScreenToggle >= 5000) {
            lastScreenToggle = currentMillis;
            showAlarmScreen = !showAlarmScreen;
            lcd.clear(); // מונע "שאריות" טקסט במעבר בין המסכים
        }
        checkAlarm(now); // בדיקה האם הגיע זמן הצלצול
    }

    // --- 4. עדכון תצוגת ה-LCD ---
    updateDisplay(now);

    // --- 5. ניהול צלצול הזמזם (צפצוף מקוטע) ---
    if (isRinging) {
        // צפצוף מקוטע (500 מילישניות עובד, 500 מילישניות כבוי)
        if ((currentMillis / 500) % 2 == 0) {
            digitalWrite(BUZZER, HIGH);
        } else {
            digitalWrite(BUZZER, LOW);
        }
    } else {
        digitalWrite(BUZZER, LOW);
    }

    delay(50); // השהייה קבועה קצרה לסינון רעשים ויציבות
}

// --- פונקציית עדכון התצוגה המרכזית ---
void updateDisplay(const RtcDateTime& dt) {
    if (currentMode == SHOW_TIME) {
        if (!showAlarmScreen) {
            // מסך שעון רגיל
            lcd.setCursor(0, 0);
            lcd.print("Date: ");
            if (dt.Day() < 10) lcd.print('0');
            lcd.print(dt.Day()); lcd.print('/');
            if (dt.Month() < 10) lcd.print('0');
            lcd.print(dt.Month()); lcd.print('/');
            
            int shortYear = dt.Year() % 100;
            if (shortYear < 10) lcd.print('0');
            lcd.print(shortYear);

            lcd.setCursor(0, 1);
            lcd.print("Time: ");
            if (dt.Hour() < 10) lcd.print('0');
            lcd.print(dt.Hour()); lcd.print(':');
            if (dt.Minute() < 10) lcd.print('0');
            lcd.print(dt.Minute()); lcd.print(':');
            if (dt.Second() < 10) lcd.print('0');
            lcd.print(dt.Second());
        } else {
            // מסך סטטוס התראה
            lcd.setCursor(0, 0);
            if (isAlarmOn) {
                lcd.print("Alarm: ACTIVE   ");
            } else {
                lcd.print("Alarm: DISABLED ");
            }
            
            lcd.setCursor(0, 1);
            lcd.print("Time:  ");
            if (alarmHour < 10) lcd.print('0');
            lcd.print(alarmHour); lcd.print(':');
            if (alarmMinute < 10) lcd.print('0');
            lcd.print(alarmMinute);
            lcd.print("      ");
        }
    } 
    else if (currentMode == SET_ALARM_HOUR) {
        lcd.setCursor(0, 0);
        lcd.print("Set Alarm Hour  ");
        lcd.setCursor(0, 1);
        lcd.print("Hour: > ");
        if (alarmHour < 10) lcd.print('0');
        lcd.print(alarmHour);
        lcd.print(" : ");
        if (alarmMinute < 10) lcd.print('0');
        lcd.print(alarmMinute);
        lcd.print(" < ");
    } 
    else if (currentMode == SET_ALARM_MINUTE) {
        lcd.setCursor(0, 0);
        lcd.print("Set Alarm Min   ");
        lcd.setCursor(0, 1);
        lcd.print("Min:  > ");
        if (alarmHour < 10) lcd.print('0');
        lcd.print(alarmHour);
        lcd.print(" : ");
        if (alarmMinute < 10) lcd.print('0');
        lcd.print(alarmMinute);
        lcd.print(" < ");
    }
}

// --- בדיקה אקטיבית של שעת ההתראה ---
void checkAlarm(const RtcDateTime& dt) {
    // אם ההתראה דולקת, השעה והדקה מתאימות, והשניות בדיוק על 0 - מפעילים צלצול
    if (isAlarmOn && dt.Hour() == alarmHour && dt.Minute() == alarmMinute && dt.Second() == 0) {
        isRinging = true;
    }
}
